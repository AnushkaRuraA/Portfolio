# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — only this .env.example is checked in.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=

# JWT secret for admin auth — generate a strong random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Cloudinary (server-side signed uploads for project images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer / Gmail SMTP
# EMAIL_USER         = your Gmail address (the sender)
# EMAIL_APP_PASSWORD = a Gmail "App Password" (NOT your normal password).
#                      Create at: https://myaccount.google.com/apppasswords
# EMAIL_TO           = where contact-form notifications are delivered
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_TO=

# Seed-only admin credentials (used by `npm run seed` to create the /mod admin).
# Not read at runtime after seeding.
ADMIN_EMAIL=anushni@gmail.com
ADMIN_PASSWORD=kidmi
